# Banco de Dados 
DB_ENGINE=django.db.backends.postgresql
DB_NAME=shio
DB_USERNAME=shio
DB_PASSWORD=shio
DB_HOSTNAME=db
DB_PORT=5432

# Django
# Gerar secret key:
# python3 -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your_secret_key
SETTINGS_FILE_PATH=core.settings.dev

# Credenciais de acesso ao admin
ADMIN_NAME=admin
ADMIN_PASS=admin
ADMIN_EMAIL=admin@gmail.com

# Google OAuth Mock
GOOGLE_CLIENT_ID=your_google_oauth2_mock_token
CORS_ALLOW_ALL_ORIGINS=True

#User da conta InfinitePay
INFINITEPAY_HANDLE=user_infinitepay

# Credenciais Correios API
CORREIOS_USERNAME=seu_usuario_meu_correios
CORREIOS_PASSWORD=sua_senha_de_componente
CORREIOS_CARTAO_POSTAGEM=seu_numero_cartao_postagem

# Pré-Postagem Correios — dados do remetente (loja)
CORREIOS_CODIGO_SERVICO=03220
CORREIOS_PESO_PADRAO_GRAMAS=300
CORREIOS_REMETENTE_NOME=Nome da Empresa
CORREIOS_REMETENTE_EMAIL=contato@empresa.com.br
CORREIOS_REMETENTE_CPF_CNPJ=00.000.000/0000-00
CORREIOS_REMETENTE_CEP=70000000
CORREIOS_REMETENTE_LOGRADOURO=Rua da Empresa
CORREIOS_REMETENTE_NUMERO=123
CORREIOS_REMETENTE_COMPLEMENTO=
CORREIOS_REMETENTE_BAIRRO=Centro
CORREIOS_REMETENTE_CIDADE=Brasilia
CORREIOS_REMETENTE_UF=DF