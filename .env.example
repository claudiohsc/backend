# Banco de Dados 
DB_ENGINE=django.db.backends.postgresql
DB_NAME=shio
DB_USERNAME=shio
DB_PASSWORD=shio
DB_HOSTNAME=db
DB_PORT=5432

# Django
# Gerar secret key:
# python3 -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your_secret_key
SETTINGS_FILE_PATH=core.settings.dev

# Credenciais de acesso ao admin
ADMIN_NAME=admin
ADMIN_PASS=admin
ADMIN_EMAIL=admin@gmail.com

# Google OAuth Mock
GOOGLE_CLIENT_ID=your_google_oauth2_mock_token
CORS_ALLOW_ALL_ORIGINS=True

# Produção — lista separada por vírgula
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SendGrid — e-mails transacionais (prod)
SENDGRID_API_KEY=your_sendgrid_api_key
DEFAULT_FROM_EMAIL=noreply@shio.com.br
SUPPORT_EMAIL=suporte@shio.com.br

# Cloudflare R2 — storage de mídia (prod)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=shio-media
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://media.example.com